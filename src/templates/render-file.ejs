<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= filePath %> - Argus</title>
  <link rel="stylesheet" href="/static/css/main.css">
  <link rel="stylesheet" href="/static/css/github-markdown-light.css">
  <style>
    .rendered-file-container {
      max-width: 900px;
      margin: 2rem auto;
      padding: 0 1rem;
    }

    .rendered-file-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid #d0d7de;
      padding-bottom: 1rem;
    }

    .rendered-file-title {
      font-size: 1.5rem;
      margin: 0 0 0.5rem 0;
      font-weight: 600;
      word-break: break-all;
    }

    .rendered-file-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.875rem;
      color: #57606a;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .rendered-file-content {
      padding: 2rem;
      background: #ffffff;
      border: 1px solid #d0d7de;
      border-radius: 6px;
    }
  </style>
</head>
<body>
  <header class="site-header">
    <nav class="nav-container">
      <a href="/" class="nav-logo">Argus</a>
      <% if (typeof user !== 'undefined' && user) { %>
        <span class="nav-user"><%= user.login %></span>
      <% } %>
    </nav>
  </header>

  <main class="main-content">
    <div class="rendered-file-container">
      <div class="rendered-file-header">
        <h1 class="rendered-file-title"><%= filePath %></h1>
        <div class="rendered-file-meta">
          <span>Commit: <code><%= sha.slice(0, 7) %></code></span>
          <a href="/pr/<%= owner %>/<%= repo %>/<%= prNumber %>?tab=files" class="btn btn-small">Back to PR</a>
        </div>
      </div>
      <div class="rendered-file-content markdown-body">
        <%- renderedContent %>
      </div>
    </div>
  </main>
</body>
</html>

